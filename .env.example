# ── Docker Compose environment template ──────────────────────────────────────
# Copy to .env and fill real values. .env is gitignored; .env.example is committed.
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=IoTAccessDb

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be >= 32 chars. Generate strong random for prod:
#   openssl rand -base64 48
JWT_SECRET=change-this-in-production-minimum-32-chars!!

# ── Seed data (first-run admin) ───────────────────────────────────────────────
# SEED_DATA=true seeds users + devices on startup (idempotent). Cards assigned later.
SEED_DATA=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── MQTT broker ───────────────────────────────────────────────────────────────
# HiveMQ Cloud (TLS + auth). Backend uses native MQTT-over-TLS :8883.
# Local dev w/ bundled Mosquitto: MQTT_TRANSPORT=tcp, MQTT_USE_TLS=false,
#   MQTT_HOST=mosquitto, MQTT_PORT=1883, empty user/pass.
MQTT_TRANSPORT=tcp
MQTT_USE_TLS=true
MQTT_HOST=your-cluster.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_WEBSOCKET_URI=your-cluster.s1.eu.hivemq.cloud:8884/mqtt
MQTT_CLIENT_ID=iot-backend
# Topic prefix optional — empty on a private cluster. Set + match firmware only if sharing a broker.
MQTT_TOPIC_PREFIX=
MQTT_USERNAME=acs-server
MQTT_PASSWORD=change-me
