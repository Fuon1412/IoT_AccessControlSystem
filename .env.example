# ── Docker Compose environment template ──────────────────────────────────────
# Copy to .env and fill real values. .env is gitignored; .env.example is committed.
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=IoTAccessDb

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be >= 32 chars. Generate strong random for prod:
#   openssl rand -base64 48
JWT_SECRET=change-this-in-production-minimum-32-chars!!

# ── Seed data (first-run admin) ───────────────────────────────────────────────
# SEED_DATA=true seeds users + devices on startup (idempotent). Cards assigned later.
SEED_DATA=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── MQTT broker ───────────────────────────────────────────────────────────────
# Public broker for college project (no auth). Backend + ESP32 must match.
# Local dev: set MQTT_HOST=mosquitto to use the bundled Mosquitto service.
MQTT_HOST=broker.hivemq.com
MQTT_PORT=1883
MQTT_CLIENT_ID=iot-backend-7f3a
# Unique namespace on shared public broker — MUST match firmware TOPIC_PREFIX.
MQTT_TOPIC_PREFIX=iot7f3a
MQTT_USERNAME=
MQTT_PASSWORD=
